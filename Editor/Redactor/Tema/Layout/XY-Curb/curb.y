/* curb.y - Координаты бордюров по вертикали */

// Определяем высоты элементов внутри окна палитры
// (Предположим, общее окно начинается с Y = 0 внутри своего контейнера)

int mesh_bottom_y = 210;       // Где заканчивается квадратная палитра
int recommendations_y = 220;   // Где начинаются кружочки цветов
int nex_input_y = 280;         // Где начинается поле ввода NEX-кодов

// Сами бордюры (ставим их ровно в промежутки)

// 1. Бордюр над рекомендациями
int curb_1_y = 215; 

// 2. Бордюр над NEX-кодом
int curb_2_y = 275;

// Функция для получения Y-позиции конкретного бордюра
int get_curb_y_pos(int index) {
    if (index == 1) return curb_1_y;
    if (index == 2) return curb_2_y;
    return 0;
}
