/* mesh.y - Вертикальное позиционирование цветового поля */

// Отступ от верхнего края окна палитры
int mesh_start_y = 15; 

// Высота квадрата (делаем его идеальным квадратом 180x180)
int mesh_height = 180; 

// Координата курсора (шарика) по вертикали (Y)
float mesh_cursor_y = 90.0f; 

// Конечная точка меша по вертикали
// Именно отсюда будет отсчитываться положение первого серого бордюра
int mesh_bottom_y = 195; // mesh_start_y + mesh_height

// Функция получения абсолютной Y-позиции
int get_mesh_pixel_y(float normalized_y) {
    // Превращает 0.0-1.0 в пиксели внутри меша (от верхнего края вниз)
    return mesh_start_y + (int)(normalized_y * mesh_height);
}
