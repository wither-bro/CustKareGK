/* mesh.x - Горизонтальное позиционирование цветового поля */

// Ширина самого квадрата палитры (Mesh)
int mesh_width = 180; 

// Центрирование меша внутри окна (при ширине окна, например, 200)
// Вычисляется как (Window_Width - mesh_width) / 2
int mesh_start_x = 10; 

// Координата курсора (шарика) по горизонтали (X)
// По умолчанию ставим в центр или на край
float mesh_cursor_x = 90.0f; 

// Функция для получения абсолютной X-позиции точки в меше
int get_mesh_pixel_x(float normalized_x) {
    // Превращает 0.0-1.0 в пиксели внутри меша
    return mesh_start_x + (int)(normalized_x * mesh_width);
}
